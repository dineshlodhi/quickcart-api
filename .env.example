# ─── Environment Variables ─────────────────────────────────────────
# This file documents every environment variable the application uses.
# Copy this to `.env` for local development:  cp .env.example .env
#
# WHY this file exists:
# Production apps are configured through environment variables, not
# hardcoded values. This lets the same Docker image run differently
# in development, staging, and production. `.env.example` is the
# checked-in documentation of what variables are expected.
#
# IMPORTANT: Never commit the actual `.env` file — it may contain secrets.
# ────────────────────────────────────────────────────────────────────

# Port the HTTP server listens on.
# Render and most cloud platforms set this automatically.
PORT=3000

# Application environment. Common values: development, production, test.
# Controls behavior like logging verbosity and error detail in responses.
NODE_ENV=development

# Display name used in health endpoint responses and startup logs.
APP_NAME=Mini Zepto Backend
