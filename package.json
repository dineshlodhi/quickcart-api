{
  "name": "mini-zepto-backend",
  "version": "1.0.0",
  "description": "A TypeScript learning project: mini quick-commerce backend inspired by Zepto",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "container:build": "podman build -t mini-zepto .",
    "container:run": "podman run -p 3000:3000 -e NODE_ENV=production --rm mini-zepto",
    "container:compose": "podman compose up"
  },
  "keywords": [
    "typescript",
    "express",
    "learning"
  ],
  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
