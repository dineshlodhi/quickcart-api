# ─── .gitignore ────────────────────────────────────────────────────
# Tells Git which files and directories to exclude from version control.
#
# Rule of thumb: don't commit anything that is either:
#   1. Reproducible from source (node_modules, dist)
#   2. Environment-specific (`.env`, editor settings)
#   3. Generated at runtime (logs, coverage reports)
# ────────────────────────────────────────────────────────────────────

# Dependencies — reproducible via `npm ci` from package-lock.json
node_modules/

# Build output — reproducible via `npm run build`
dist/

# Environment variables — may contain secrets, never commit
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~
